#!/bin/sh

# Config
CONFIG_DIR="$HOME/nixos-config"  # <-- Change this to your actual config path

# Enter config directory
cd "$CONFIG_DIR" || {
    echo "Error: Can't access $CONFIG_DIR" >&2
    exit 1
}

# Verify we're in a git repo
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Not a git repository" >&2
    exit 1
fi

# Edit configuration files
# nvim -c 'lua Snacks.picker.files({cwd = [[~/nixos-config]] })'

nvim ~/nixos-config

# Commit changes if any
if [ -n "$(git status --porcelain)" ]; then
    git add .
    timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    git commit -m "nixos: $timestamp"
    
    # Rebuild system with confirmation
    echo "Rebuilding system..."
    if sudo nixos-rebuild switch; then
        echo "Successfully rebuilt system!"
        echo ""
        echo "Changes applied:"
        git diff HEAD~1 HEAD
       git push
    else
        echo "Rebuild failed! Check output above." >&2
        exit 1
    fi
else
    echo "No changes made to NixOS config."
fi
